# --- Supabase ---
# Project URL and keys: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses RLS for uploads + profile creation. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string — USE THE POOLER (port 6543) for serverless/Vercel.
# Supabase Dashboard → Settings → Database → Connection pooling
DATABASE_URL=postgresql://postgres.your-ref:password@aws-1-region.pooler.supabase.com:6543/postgres

# --- Google Gemini (free tier) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Current text/OCR model (embeddings always use gemini-embedding-001 @ 768 dims)
GEMINI_MODEL=gemini-3.1-flash-lite
